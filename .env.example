PORT=8787
VITE_ENABLE_SW_IN_DEV=false

# Provider order used when Provider = Auto
# Example: mistral,ollama,openrouter
AI_PROVIDER_CANDIDATES=mistral,ollama,openrouter
AI_STRICT_GENERATION=1
AI_DISABLE_LOCAL_FALLBACK_CONTENT=1
AI_GENERATION_CACHE_ENABLED=0
AI_MAX_OUTPUT_TOKENS=900

# Disable providers you do not want to use.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODELS=mistralai/mistral-small-3.2-24b-instruct:free,mistralai/ministral-8b,meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MAX_TOKENS=900
OPENROUTER_INTERVIEW_MAX_KEYS=4

# Mistral AI
MISTRAL_API_KEY=
MISTRAL_API_KEYS=
MISTRAL_MODELS=mistral-small-latest,ministral-8b-latest

# Ollama (local default)
OLLAMA_API_BASE=http://127.0.0.1:11434
OLLAMA_API_KEY=
OLLAMA_MODELS=llama3.2:3b,llama3.1:8b

# YouTube Search (optional)
YOUTUBE_API_KEY=

# Supabase target architecture
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENROUTER_TRANSCRIPTION_MODEL=google/gemini-2.5-flash
