# ====== Server config ======
PORT=8787

# ====== Supabase (Auth + DB) ======
# Never expose service role key in frontend code.
SUPABASE_URL=XXXXXXXXXXXXXXXXX
SUPABASE_ANON_KEY=XXXXXXXXXXXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=XXXXXXXXXXXXXXXXX

VITE_ENABLE_SW_IN_DEV=true

# Provider order used when Provider = Auto
# Example: openrouter,mistral
AI_PROVIDER_CANDIDATES=openrouter
AI_STRICT_GENERATION=1
AI_DISABLE_LOCAL_FALLBACK_CONTENT=1
AI_GENERATION_CACHE_ENABLED=0
AI_MAX_OUTPUT_TOKENS=900
# Provider HTTP timeout (ms) before retry/fallback kicks in.
AI_PROVIDER_TIMEOUT_MS=120000
INTERVIEW_GENERATION_DEBUG=1


# ====== OpenRouter ======
OPENROUTER_API_KEY=XXXXXXXXXXXXX
OPENROUTER_API_KEYS=XXXXXXXXXXXX,YYYYYYYYYYYYYYYY,AAAAAAAAAAAAAA,BBBBBBBBBBBBBB
# Hard cap to reduce budget/rate-limit pressure.
OPENROUTER_MAX_TOKENS=700
OPENROUTER_INTERVIEW_MAX_KEYS=4
# ====== Mistral AI ======
MISTRAL_API_KEY=XXXXXXXXXXXXXXXXXX

MISTRAL_API_KEYS=XXXXXXXXXXXXXXXX,YYYYYYYYYYYYYYYY,AAAAAAAAAAAAAAAA
MISTRAL_MODELS=open-mistral-nemo

# ====== YouTube Search (optional) ======
# If provided, VIDEO steps will fetch a real top search result.
YOUTUBE_API_KEY=XXXXXXXXXXXXXXXXXXXXX

